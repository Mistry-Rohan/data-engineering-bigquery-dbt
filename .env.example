# Project and region
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1

# Storage
GCS_RAW_BUCKET=your-project-taxi-raw

# BigQuery datasets
BQ_BRONZE_DATASET=taxi_bronze
BQ_SILVER_DATASET=taxi_silver
BQ_GOLD_DATASET=taxi_gold

# Local Airflow worker scratch space
AIRFLOW_DATA_DIR=/tmp/nyc_taxi_pipeline

# NYC TLC source URL
NYC_TLC_URL_PREFIX=https://d37ci6vzurychx.cloudfront.net/trip-data

# Local development only:
# Do not commit credentials to GitHub.
# Prefer runtime identity in Composer and attached service accounts in GCP.
# If you need local ADC with Docker, mount your local credentials file rather
# than putting secrets into environment variables.
